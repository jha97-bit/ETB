# Mock Interview AI - Environment Variables (Hugging Face)
# Copy to .env and fill in your values

# Hugging Face (required)
HUGGINGFACEHUB_API_TOKEN=hf_...

# Optional: Skip embeddings (for offline testing)
# HF_SKIP_EMBEDDINGS=true

# Optional: Override model IDs
# HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# HF_WHISPER_MODEL=openai/whisper-large-v3
# HF_TTS_MODEL=facebook/mms-tts-eng

# Vector store
CHROMA_PERSIST_DIR=./data/chroma
